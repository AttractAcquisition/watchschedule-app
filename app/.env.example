# WatchSchedule frontend env (Vite, build-time, PUBLIC only).
# Copy to .env and fill in. NEVER put secret keys here — the client holds the
# anon key only (master.md §2 invariants; backend.md golden rules).
VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_APP_URL=https://app.watchschedule.com
